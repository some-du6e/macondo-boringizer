{
  "manifest_version": 3,
  "name": "HCTG+",
  "description": "better game.hackclub.com",
  "version": "1.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "kdndfafcpodecbbjhoicneekmbdhhckm@chromeisbetter"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://game.hackclub.com/*"],
      "js": [
        "components/consts.js",
        "components/data.js",
        "components/goals.js",
        "components/otherpersonprojectviewer.js",
        "components/sidebar.js",
        "components/shop.js",
        "components/projects.js",
        "components/gallery.js",
        "components/lander.js",
        "components/settings.js",
        "components/notifications.js",
        "components/larp_reviewer.js",
        "components/larping_reviewing.js"
      ],
      "run_at": "document_idle"
    },

    {
      "matches": ["*://*.game.hackclub.com/*"],
      "js": ["components/utils.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.game.hackclub.com/*"],
      "js": ["components/larping.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/hours.svg", "icons/repo.svg", "icons/demo.svg", "icons/readme.svg"],
      "matches": ["https://game.hackclub.com/*"]
    }
  ]
}
