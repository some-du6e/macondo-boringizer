{
    "$schema": "https://json.schemastore.org/chrome-manifest.json",
    "chromium:manifest_version": 3,
    "firefox:manifest_version": 2,
    "version": "1.0.0",
    "name": "Macondo Boringizer",
    "description": "Content script example built with TypeScript. Mounts a small UI and uses typed modules.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "64": "icons/icon64.png",
        "128": "icons/icon128.png"
    },
    "host_permissions": ["<all_urls>"],
    "content_scripts": [
        {
            "matches": ["*://macondo.hackclub.com/*"],
            "js": ["components/homepage.ts"],
            "run_at": "document_idle"
        }
    ]
}
