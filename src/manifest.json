{
  "manifest_version": 3,
  "name": "Macondo boringizer+",
  "description": "better macondo.hackclub.com",
  "version": "0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "kdndfafcpodecbbjhoicneekmbdhhckm@chromeisbetter"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://macondo.hackclub.com/*"],
      "js": ["components/homepage.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/hours.svg", "icons/repo.svg", "icons/demo.svg", "icons/readme.svg"],
      "matches": ["https://game.hackclub.com/*"]
    }
  ]
}
